while($r=$res->fetch_assoc()){
echo "<tr>
<td>{$r['name']}</td>
<td>{$r['email']}</td>
<td>{$r['dob']}</td>
<td>{$r['department']}</td>
</tr>";
}
?>

</table>

<h3 style="text-align:center">Students per Department</h3>

<?php
$c=$conn->query("SELECT department,COUNT(*) total FROM students GROUP BY department");

while($r=$c->fetch_assoc()){
echo "<p style='text-align:center'>{$r['department']} : {$r['total']}</p>";
}
?>

