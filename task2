<?php
$conn=new mysqli("localhost","root","","studentdb");

$sort=isset($_GET['sort'])?$_GET['sort']:"name";
$dept=isset($_GET['dept'])?$_GET['dept']:"";

$sql="SELECT * FROM students";

if($dept!=""){
$sql.=" WHERE department='$dept'";
}

$sql.=" ORDER BY $sort";

$res=$conn->query($sql);
?>

